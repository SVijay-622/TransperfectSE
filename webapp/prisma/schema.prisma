generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  VIEWER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      Role     @default(VIEWER)
  teamId    String?
  team      Team?    @relation(fields: [teamId], references: [id])
  createdAt DateTime @default(now())
}

model Team {
  id        String   @id @default(cuid())
  name      String
  users     User[]
}

model Ticket {
  id            String   @id @default(cuid())
  externalId    String   @unique // Original ID from Excel for deduplication
  title         String
  description   String?
  status        String   // e.g. Open, In Progress, Blocked, Closed
  priority      String
  assigneeName  String?
  createdAt     DateTime // From external system
  updatedAt     DateTime // From external system
  closedAt      DateTime?
  
  // Analytics relationships
  statusHistory TicketStatusHistory[]
  
  // Critical indexes for analytical queries
  @@index([status])
  @@index([assigneeName])
  @@index([createdAt])
  @@index([status, assigneeName])
}

// Tracks the exact timeline of a ticket to map bottlenecks
model TicketStatusHistory {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  status     String
  changedAt  DateTime // Extracted from file audit logs or computed
  durationMs BigInt?  // Precomputed duration the ticket spent in this status
  
  @@index([ticketId])
  @@index([changedAt])
}

// Time-series snapshots of the entire company's state. 
// Used for high-speed trend charts without calculating from millions of rows.
model DailyMetricsSnapshot {
  id           String   @id @default(cuid())
  date         DateTime @db.Date @unique
  openCount    Int
  closedCount  Int
  avgAgeHours  Float
  slaBreaches  Int
  createdAt    DateTime @default(now())
}

// Job tracking for transparency and error handling
model UploadJob {
  id         String   @id @default(cuid())
  fileName   String
  status     JobStatus @default(PENDING)
  totalRows  Int?
  processed  Int      @default(0)
  errors     Json?    // Detailed row-level error log
  uploadedBy String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
